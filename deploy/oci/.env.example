PORT=8000
VLEGAL_ENVIRONMENT=production
VLEGAL_PUBLIC_BASE_URL=https://api.your-domain.com
VLEGAL_CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app,http://localhost:3000

# Database path inside container - mount a persistent host path to /app/data via docker-compose volumes
VLEGAL_DATABASE_PATH=/app/data/full_hf.sqlite

# Appwrite Database
VLEGAL_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VLEGAL_APPWRITE_PROJECT_ID=your_project_id
VLEGAL_APPWRITE_DATABASE_ID=your_database_id
VLEGAL_APPWRITE_API_KEY=your_api_key
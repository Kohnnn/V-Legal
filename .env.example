VLEGAL_ENVIRONMENT=development
VLEGAL_PUBLIC_BASE_URL=http://127.0.0.1:8000
VLEGAL_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VLEGAL_DATABASE_PATH=data/vlegal.sqlite
VLEGAL_DEFAULT_IMPORT_LIMIT=500
VLEGAL_SEARCH_PAGE_SIZE=12
VLEGAL_ANSWER_PASSAGE_LIMIT=6
VLEGAL_PHAPDIEN_MAIN_URL=https://phapdien.moj.gov.vn/TraCuuPhapDien/MainBoPD.aspx

# Appwrite Database (replace SQLite in production)
VLEGAL_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VLEGAL_APPWRITE_PROJECT_ID=your_project_id
VLEGAL_APPWRITE_DATABASE_ID=your_database_id
VLEGAL_APPWRITE_API_KEY=your_api_key

# OCI Backend Deployment (used by scripts/deploy_oci.py)
# Full SSH command with key path and user@host, e.g.:
# OCI_SSH_CONNECT=ssh -i "C:\Users\Admin\.ssh\XXX" ubuntu@X.X.X.X
OCI_SSH_CONNECT=ssh -i "C:\Users\Admin\.ssh\your_key" ubuntu@your_instance_ip

# Secret key for sessions (auto-generated if blank)
VLEGAL_SECRET_KEY=